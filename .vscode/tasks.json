{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve",
      "type": "shell",
      "command": "docsify serve ./docs",
      "options": {
        "env": {
          "CHOKIDAR_USEPOLLING": "1"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Export PDF",
      "type": "shell",
      "command": "node ./scripts/export-pdf.mjs",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "CHOKIDAR_USEPOLLING": "1"
        }
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
